{{- if and .features.java (eq .chezmoi.os "darwin") -}}
#!/bin/bash
set -e

. "{{ .chezmoi.sourceDir }}/script-helpers.sh"
require_homebrew

installing_feature "Java"

install_packages <<'EOB'
# Install standard Java build tools
brew "ant"
brew "ant-contrib"
brew "maven"
brew "gradle"
brew "bazelisk"
EOB

# vim: syntax=bash filetype=bash
{{ end -}}
